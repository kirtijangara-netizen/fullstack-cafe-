<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <style>
        body {
            font-family: Arial;
            background: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .box {
            background: white;
            padding: 30px;
            width: 350px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h2 { text-align: center; }
        input {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            box-sizing: border-box;
        }
        button {
            width: 100%;
            padding: 10px;
            background: #007bff;
            color: white;
            border: none;
            cursor: pointer;
            margin-top: 10px;
            border-radius: 4px;
        }
        button:hover { background: #0056b3; }
        a { text-decoration: none; color: #007bff; }
        a:hover { text-decoration: underline; }
        .message { color: green; text-align: center; margin-bottom: 10px; display: none; }
        .error { color: red; text-align: center; margin-bottom: 10px; display: none; }
    </style>
</head>
<body>



<div class="box">
    <h2>Login</h2>

    <!-- Signup Success Message -->
    <div id="signupSuccess" class="message">Signup successful! Please login.</div>
    <!-- Login Error Message -->
    <div id="loginError" class="error"></div>

    <form id="loginForm">
        <input type="email" id="email" name="email" placeholder="Enter Email" required>
        <input type="password" id="password" name="password" placeholder="Enter Password" required>
        <button type="submit">Login</button>
    </form>

    <p style="text-align:center; margin-top:10px;">
        Don't have an account? <a href="/signup">Signup</a>
    </p>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const loginForm = document.getElementById("loginForm");
    const loginError = document.getElementById("loginError");
    const signupSuccess = document.getElementById("signupSuccess");

    // Show signup success message if query param exists
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get("signup") === "success") {
        signupSuccess.style.display = "block";
    }

    loginForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const email = document.getElementById("email").value;
        const password = document.getElementById("password").value;

        try {
            const res = await fetch("/login", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, password })
            });

            const data = await res.json();

            if (data.success) {
                // Redirect to products page after successful login
                window.location.href = data.redirect;
            } else {
                loginError.style.display = "block";
                loginError.textContent = data.message || "Login failed";
            }
        } catch (err) {
            loginError.style.display = "block";
            loginError.textContent = "Server error. Please try again later.";
        }
    });
});
</script>

</body>
</html>