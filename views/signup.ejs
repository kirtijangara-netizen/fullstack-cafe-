<!DOCTYPE html>
<html>
<head>
    <title>fullstack Registration</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .amazon-box { border: 1px solid #ddd; border-radius: 8px; width: 350px; background: white; padding: 20px 26px; }
        .amz-input { border: 1px solid #a6a6a6; border-radius: 3px; padding: 7px 10px; width: 100%; margin-top: 3px; }
        .amz-input:focus { border-color: #e77600; box-shadow: 0 0 3px 2px rgba(228,121,17,.5); outline: none; }
        .btn-send-otp { background: #e7e9ec; border: 1px solid #adb1b8; border-radius: 3px; padding: 5px; font-size: 12px; cursor: pointer; }
        .btn-signup { background: linear-gradient(to bottom, #f7dfa5, #f0c14b); border: 1px solid #a88734; border-radius: 3px; padding: 8px; width: 100%; margin-top: 15px; cursor: pointer; }
    </style>
</head>
<body class="bg-white flex flex-col items-center pt-10 font-sans">

    <div class="mb-6">
        <h1 class="text-2xl font-bold">fullstack<span class="text-orange-500">Central</span></h1>
    </div>

    <div class="amazon-box shadow-sm">
        <h2 class="text-2xl font-normal mb-4">Create Account</h2>
        
        <div id="msg" class="text-xs mb-3 hidden"></div>

        <form id="signupForm" class="space-y-3">
            <div>
                <label class="text-xs font-bold">Your name</label>
                <input type="text" id="name" placeholder="First and last name" class="amz-input" required>
            </div>

            <div>
                <label class="text-xs font-bold">Email</label>
                <div class="flex gap-2">
                    <input type="email" id="email" class="amz-input" required>
                    <button type="button" id="otpBtn" class="btn-send-otp whitespace-nowrap">Send OTP</button>
                </div>
            </div>

            <div>
                <label class="text-xs font-bold">Password</label>
                <input type="password" id="password" placeholder="At least 6 characters" class="amz-input" required>
            </div>

            <div id="otpSection" class="hidden">
                <label class="text-xs font-bold text-blue-700">Enter OTP sent to email</label>
                <input type="text" id="otp" placeholder="6-digit code" class="amz-input border-blue-400">
            </div>

            <button type="submit" class="btn-signup font-medium text-sm">Verify email</button>
        </form>

        <hr class="my-6 border-gray-200">
        <p class="text-xs">Already have an account? <a href="/login" class="text-blue-700 hover:underline hover:text-orange-600">Sign in</a></p>
    </div>

    <script>
        const otpBtn = document.getElementById('otpBtn');
        const otpSection = document.getElementById('otpSection');
        const msg = document.getElementById('msg');

        // Step 1: Send OTP
        otpBtn.addEventListener('click', async () => {
            const email = document.getElementById('email').value;
            if(!email) return alert("Enter email first");
            
            otpBtn.innerText = "Sending...";
            const res = await fetch('/send-otp', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ email })
            });
            const data = await res.json();
            
            if(data.success) {
                otpSection.classList.remove('hidden');
                msg.className = "text-xs mb-3 text-green-600 block";
                msg.innerText = "OTP sent! Check your inbox.";
                otpBtn.innerText = "Resend";
            } else {
                alert(data.message);
                otpBtn.innerText = "Send OTP";
            }
        });

        // Step 2: Final Signup
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const payload = {
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                password: document.getElementById('password').value,
                otp: document.getElementById('otp').value
            };

            const res = await fetch('/signup', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(payload)
            });
            const data = await res.json();

            if(data.success) {
                window.location.href = data.redirect;
            } else {
                msg.className = "text-xs mb-3 text-red-600 block";
                msg.innerText = data.message;
            }
        });
    </script>
</body>
</html>