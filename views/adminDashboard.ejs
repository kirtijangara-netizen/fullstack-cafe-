<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel | Gourmet Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: { extend: { colors: { primary: "#111827", accent: "#2563eb" } } }
        }
    </script>
    <style>
        .active-tab { background: #111827; color: white; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .input-style { border: 1px solid #e5e7eb; padding: 12px; border-radius: 12px; outline: none; width: 100%; transition: all 0.2s; }
        .input-style:focus { border-color: #2563eb; ring: 2px; ring-color: #bfdbfe; }
        .animate-fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>

<body class="bg-slate-50 min-h-screen font-sans text-slate-900">

<nav class="bg-white/90 backdrop-blur-md border-b border-slate-200 px-8 py-4 flex justify-between items-center sticky top-0 z-50">
    <div class="flex items-center gap-2">
        <div class="bg-accent p-2 rounded-lg text-white"><i class="fa-solid fa-utensils"></i></div>
        <h1 class="text-xl font-black tracking-tight text-slate-800 uppercase">Admin<span class="text-accent">Hub</span></h1>
    </div>
    <a href="/logout" class="bg-red-50 text-red-600 hover:bg-red-600 hover:text-white px-5 py-2 rounded-xl font-bold transition-all duration-200 shadow-sm flex items-center gap-2">
        <i class="fa-solid fa-sign-out-alt"></i> Logout
    </a>
</nav>

<div class="max-w-7xl mx-auto px-6 py-10">

    <div class="inline-flex p-1 bg-slate-200/50 rounded-2xl mb-10 shadow-inner">
        <button id="btn-orders" onclick="switchTab('orders', event)" class="tab-btn active-tab px-10 py-3 rounded-xl font-bold transition-all">Orders</button>
        <button id="btn-products" onclick="switchTab('products', event)" class="tab-btn px-10 py-3 rounded-xl font-bold text-slate-500 hover:text-slate-700 transition-all">Products</button>
    </div>

    <div id="orders-section" class="tab-content space-y-8">
        <% if (orders.length === 0) { %> 
            <div class="text-center py-24 bg-white rounded-[2rem] border-2 border-dashed border-slate-200 text-slate-400">
                <i class="fa-solid fa-receipt text-5xl mb-4 opacity-20"></i>
                <p class="text-lg font-medium">No orders received yet.</p>
            </div> 
        <% } %>

        <% orders.forEach(order => { %>
        <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100 hover:shadow-md transition-all animate-fade-in">
            <div class="flex flex-col md:flex-row justify-between md:items-start border-b border-slate-50 pb-6 mb-6 gap-4">
                <div>
                    <span class="text-[10px] font-black text-accent bg-blue-50 px-3 py-1 rounded-full uppercase tracking-tighter mb-2 inline-block">Order #<%= order._id.toString().slice(-6) %></span>
                    <h3 class="text-2xl font-black text-slate-800 leading-none mb-1"><%= order.user?.name || "Guest Customer" %></h3>
                    <p class="text-slate-400 text-sm font-medium"><i class="fa-regular fa-envelope mr-1"></i> <%= order.user?.email || "No email" %></p>
                </div>
                <div class="text-right">
                    <p class="text-3xl font-black text-slate-900 tracking-tight">₹<%= order.totalAmount %></p>
                    <span id="status-badge-<%= order._id %>" class="inline-block mt-2 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest 
                        <%= order.status === 'Delivered' ? 'bg-emerald-100 text-emerald-700' : 
                            order.status === 'Cancelled' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
                        <%= order.status %>
                    </span>
                </div>
            </div>

            <div class="bg-slate-50/80 rounded-2xl p-6 mb-8 border border-slate-100">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Items Ordered</p>
                <div class="space-y-4">
                    <% order.items.forEach(item => { %>
                        <div class="flex justify-between items-center border-b border-slate-200/40 pb-3 last:border-0 last:pb-0">
                            <div class="flex items-center gap-4">
                                <div class="bg-white h-11 w-11 rounded-xl flex items-center justify-center font-black text-accent shadow-sm text-sm border border-slate-100">
                                    <%= item.quantity %>x
                                </div>
                                <div>
                                    <p class="font-black text-slate-800 text-base">
                                        <%= item.productId ? item.productId.name : (item.name || "Item Name") %>
                                    </p>
                                    <p class="text-[11px] text-slate-400 font-bold uppercase tracking-tighter">Rate: ₹<%= item.price %></p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="font-black text-slate-800">₹<%= item.price * item.quantity %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <button onclick="updateStatus('<%= order._id %>', 'Pending')" class="px-5 py-2.5 bg-slate-100 text-slate-600 rounded-xl text-xs font-black hover:bg-slate-800 hover:text-white transition-all uppercase">Pending</button>
                <button onclick="updateStatus('<%= order._id %>', 'Preparing')" class="px-5 py-2.5 bg-amber-100 text-amber-700 rounded-xl text-xs font-black hover:bg-amber-500 hover:text-white transition-all uppercase">Preparing</button>
                <button onclick="updateStatus('<%= order._id %>', 'Delivered')" class="px-5 py-2.5 bg-emerald-100 text-emerald-700 rounded-xl text-xs font-black hover:bg-emerald-600 hover:text-white transition-all uppercase">Delivered</button>
                <button onclick="updateStatus('<%= order._id %>', 'Cancelled')" class="px-5 py-2.5 bg-red-100 text-red-700 rounded-xl text-xs font-black hover:bg-red-600 hover:text-white transition-all uppercase">Cancel</button>
            </div>
        </div>
        <% }) %>
    </div>

    <div id="products-section" class="tab-content hidden animate-fade-in">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 mb-10">
            <h2 class="text-xl font-black text-slate-800 mb-8 flex items-center gap-3"><i class="fa-solid fa-plus-circle text-accent"></i> Add Product</h2>
            <form action="/admin/add-product" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Product Name</label>
                    <input type="text" name="name" required class="input-style">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Price (₹)</label>
                    <input type="number" name="price" required class="input-style">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Category</label>
                    <input type="text" name="category" required class="input-style">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Initial Stock</label>
                    <input type="number" name="stock" required class="input-style" placeholder="0">
                </div>
                <div class="md:col-span-4 space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Description</label>
                    <textarea name="description" required class="input-style h-24 resize-none"></textarea>
                </div>
                <div class="md:col-span-3 space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Image</label>
                    <input type="file" name="image" required class="input-style py-2">
                </div>
                <button type="submit" class="bg-accent text-white rounded-2xl font-black py-4 mt-auto hover:bg-blue-700 transition-all">Add to Menu</button>
            </form>
        </div>

        <div id="product-list-container" class="grid gap-5">
            <% products.forEach(product => { %>
            <div id="product-card-<%= product._id %>" class="bg-white p-6 rounded-3xl shadow-sm flex flex-col md:flex-row justify-between items-center border border-slate-100 gap-6 animate-fade-in">
                <div class="flex items-center gap-6 w-full">
                    <img src="<%= product.image %>" class="w-24 h-24 object-cover rounded-2xl border border-slate-50">
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <p class="font-black text-xl text-slate-800 item-name"><%= product.name %></p>
                            <span class="text-[9px] font-black bg-slate-100 text-slate-500 px-2 py-0.5 rounded-md uppercase tracking-tighter"><%= product.category %></span>
                            <span class="item-stock-badge text-[9px] font-black px-2 py-0.5 rounded-md uppercase <%= product.stock > 5 ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600' %>">
                                Stock: <span class="item-stock-val"><%= product.stock %></span>
                            </span>
                        </div>
                        <p class="text-accent font-black text-lg item-price">₹<%= product.price %></p>
                        <p class="text-slate-400 text-xs italic line-clamp-1 item-desc"><%= product.description %></p>
                    </div>
                </div>
                <div class="flex gap-3 w-full md:w-auto">
                    <button onclick="openEditModal('<%= product._id %>', '<%= product.name %>', '<%= product.price %>', `<%= product.description %>`, '<%= product.stock %>')" class="flex-1 bg-slate-100 px-6 py-3 rounded-xl font-bold text-slate-600 hover:bg-slate-200 transition">Edit</button>
                    <button onclick="toggleProduct('<%= product._id %>', this)" 
                        class="flex-1 <%= product.isAvailable ? 'bg-emerald-500 hover:bg-emerald-600' : 'bg-slate-400 hover:bg-slate-500' %> text-white px-6 py-3 rounded-xl font-bold shadow-sm transition-all duration-200">
                        <%= product.isAvailable ? 'Live' : 'Hidden' %>
                    </button>
                </div>
            </div>
            <% }) %>
        </div>

        <div id="pagination-container" class="flex justify-center items-center gap-4 mt-12 pb-10">
            <% if (totalPages > 1) { %>
                <% if (currentPage > 1) { %>
                    <button onclick="changePage('<%= currentPage - 1 %>')" class="px-5 py-2.5 bg-white border border-slate-200 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition shadow-sm">Prev</button>
                <% } %>
                <div class="flex items-center gap-2">
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <button onclick="changePage('<%= i %>')" 
                           class="w-10 h-10 flex items-center justify-center rounded-xl font-black transition-all <%= currentPage === i ? 'bg-accent text-white shadow-lg scale-110' : 'bg-white text-slate-400 border border-slate-200 hover:border-accent' %>">
                           <%= i %>
                        </button>
                    <% } %>
                </div>
                <% if (currentPage < totalPages) { %>
                    <button onclick="changePage('<%= currentPage + 1 %>')" class="px-5 py-2.5 bg-white border border-slate-200 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition shadow-sm">Next</button>
                <% } %>
            <% } %>
        </div>
    </div>
</div>

<div id="editModal" class="hidden fixed inset-0 bg-slate-900/70 backdrop-blur-sm flex items-center justify-center z-[100] p-4">
    <div class="bg-white p-10 rounded-[3rem] shadow-2xl w-full max-w-lg">
        <h2 class="text-3xl font-black mb-8 text-slate-800">Edit Product</h2>
        <form id="editForm" onsubmit="submitEdit(event)" class="space-y-6">
            <input type="hidden" id="editId">
            <div>
                <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Product Name</label>
                <input type="text" id="editName" class="input-style mt-1 font-bold text-slate-700" required>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Price (₹)</label>
                    <input type="number" id="editPrice" class="input-style mt-1 font-bold text-slate-700" required>
                </div>
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Stock Qty</label>
                    <input type="number" id="editStock" class="input-style mt-1 font-bold text-slate-700" required>
                </div>
            </div>
            <div>
                <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Description</label>
                <textarea id="editDescription" class="input-style mt-1 h-32 resize-none font-medium text-slate-600" required></textarea>
            </div>
            <div class="flex gap-4 pt-4">
                <button type="button" onclick="closeEditModal()" class="flex-1 bg-slate-100 py-4 rounded-2xl font-black text-slate-500">Discard</button>
                <button type="submit" id="updateBtn" class="flex-1 bg-accent text-white py-4 rounded-2xl font-black shadow-lg hover:bg-blue-700 transition-all">Update Info</button>
            </div>
        </form>
    </div>
</div>

<script>
// --- NO-REFRESH ORDER STATUS UPDATE ---
async function updateStatus(id, status) {
    try {
        const res = await fetch('/admin/update-order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderId: id, status })
        });
        
        const data = await res.json();
        if (data.success) {
            const badge = document.getElementById(`status-badge-${id}`);
            if (badge) {
                badge.innerText = status;
                badge.className = "inline-block mt-2 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all duration-300";
                if (status === 'Delivered') badge.classList.add('bg-emerald-100', 'text-emerald-700');
                else if (status === 'Cancelled') badge.classList.add('bg-red-100', 'text-red-700');
                else badge.classList.add('bg-amber-100', 'text-amber-700');
            }
        }
    } catch (err) { console.error("Update failed:", err); }
}

// --- NO-REFRESH PRODUCT EDIT ---
async function submitEdit(event) {
    event.preventDefault();
    const id = document.getElementById('editId').value;
    const btn = document.getElementById('updateBtn');
    
    const payload = { 
        name: document.getElementById('editName').value, 
        price: document.getElementById('editPrice').value, 
        description: document.getElementById('editDescription').value,
        stock: document.getElementById('editStock').value
    };

    btn.innerText = "Saving...";
    btn.disabled = true;

    try {
        const res = await fetch(`/admin/edit-product/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
            const card = document.getElementById(`product-card-${id}`);
            if (card) {
                card.querySelector('.item-name').innerText = data.product.name;
                card.querySelector('.item-price').innerText = `₹${data.product.price}`;
                card.querySelector('.item-desc').innerText = data.product.description;
                
                // Update Stock UI
                const stockVal = card.querySelector('.item-stock-val');
                const stockBadge = card.querySelector('.item-stock-badge');
                stockVal.innerText = data.product.stock;
                stockBadge.className = `item-stock-badge text-[9px] font-black px-2 py-0.5 rounded-md uppercase ${data.product.stock > 5 ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600'}`;
                
                // Update Edit Button attributes
                const editBtn = card.querySelector('button[onclick^="openEditModal"]');
                editBtn.setAttribute('onclick', `openEditModal('${id}', '${data.product.name}', '${data.product.price}', \`${data.product.description}\`, '${data.product.stock}')`);
            }
            closeEditModal();
        }
    } catch (err) { alert("Error updating product."); }
    finally {
        btn.innerText = "Update Info";
        btn.disabled = false;
    }
}

// --- NO-REFRESH PAGINATION ---
async function changePage(page) {
    try {
        const res = await fetch(`/admin?page=${page}&ajax=true`);
        const data = await res.json();
        if (data.success) {
            const listContainer = document.getElementById('product-list-container');
            listContainer.innerHTML = ''; 

            data.products.forEach(p => {
                listContainer.innerHTML += `
                <div id="product-card-${p._id}" class="bg-white p-6 rounded-3xl shadow-sm flex flex-col md:flex-row justify-between items-center border border-slate-100 gap-6 animate-fade-in">
                    <div class="flex items-center gap-6 w-full">
                        <img src="${p.image}" class="w-24 h-24 object-cover rounded-2xl border border-slate-50">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 mb-1">
                                <p class="font-black text-xl text-slate-800 item-name">${p.name}</p>
                                <span class="text-[9px] font-black bg-slate-100 text-slate-500 px-2 py-0.5 rounded-md uppercase tracking-tighter">${p.category}</span>
                                <span class="item-stock-badge text-[9px] font-black px-2 py-0.5 rounded-md uppercase ${p.stock > 5 ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600'}">
                                    Stock: <span class="item-stock-val">${p.stock}</span>
                                </span>
                            </div>
                            <p class="text-accent font-black text-lg item-price">₹${p.price}</p>
                            <p class="text-slate-400 text-xs italic line-clamp-1 item-desc">${p.description}</p>
                        </div>
                    </div>
                    <div class="flex gap-3 w-full md:w-auto">
                        <button onclick="openEditModal('${p._id}', '${p.name}', '${p.price}', \`${p.description}\`, '${p.stock}')" class="flex-1 bg-slate-100 px-6 py-3 rounded-xl font-bold text-slate-600 hover:bg-slate-200 transition">Edit</button>
                        <button onclick="toggleProduct('${p._id}', this)" 
                            class="flex-1 ${p.isAvailable ? 'bg-emerald-500 hover:bg-emerald-600' : 'bg-slate-400 hover:bg-slate-500'} text-white px-6 py-3 rounded-xl font-bold shadow-sm transition-all duration-200">
                            ${p.isAvailable ? 'Live' : 'Hidden'}
                        </button>
                    </div>
                </div>`;
            });
            renderPagination(data.currentPage, data.totalPages);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    } catch (err) { console.error("Pagination error:", err); }
}

function renderPagination(current, total) {
    const container = document.getElementById('pagination-container');
    let html = '';
    if (total <= 1) { container.innerHTML = ''; return; }
    
    if (current > 1) html += `<button onclick="changePage('${current - 1}')" class="px-5 py-2.5 bg-white border border-slate-200 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition shadow-sm">Prev</button>`;
    
    html += '<div class="flex items-center gap-2">';
    for(let i = 1; i <= total; i++) {
        html += `<button onclick="changePage('${i}')" class="w-10 h-10 flex items-center justify-center rounded-xl font-black transition-all ${parseInt(current) === i ? 'bg-accent text-white shadow-lg scale-110' : 'bg-white text-slate-400 border border-slate-200 hover:border-accent'}">${i}</button>`;
    }
    html += '</div>';
    
    if (current < total) html += `<button onclick="changePage('${parseInt(current) + 1}')" class="px-5 py-2.5 bg-white border border-slate-200 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition shadow-sm">Next</button>`;
    
    container.innerHTML = html;
}

// --- TAB & MODAL HELPERS ---
function switchTab(tab, event) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
    document.getElementById(tab + '-section').classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active-tab');
        btn.classList.add('text-slate-500');
    });
    const targetBtn = event.currentTarget || document.getElementById('btn-' + tab);
    targetBtn.classList.add('active-tab');
    targetBtn.classList.remove('text-slate-500');
}

function openEditModal(id, name, price, desc, stock) {
    document.getElementById('editId').value = id;
    document.getElementById('editName').value = name;
    document.getElementById('editPrice').value = price;
    document.getElementById('editDescription').value = desc;
    document.getElementById('editStock').value = stock || 0;
    document.getElementById('editModal').classList.remove('hidden');
}

function closeEditModal() { document.getElementById('editModal').classList.add('hidden'); }

async function toggleProduct(id, btn) {
    try {
        const res = await fetch(`/admin/toggle-product/${id}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            btn.innerText = data.isAvailable ? 'Live' : 'Hidden';
            btn.className = `flex-1 ${data.isAvailable ? 'bg-emerald-500 hover:bg-emerald-600' : 'bg-slate-400 hover:bg-slate-500'} text-white px-6 py-3 rounded-xl font-bold shadow-sm transition-all`;
        }
    } catch (err) { console.error(err); }
}
</script>
</body>
</html>