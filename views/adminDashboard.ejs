<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#111827",
                        accent: "#2563eb"
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gradient-to-br from-gray-100 to-gray-200 min-h-screen font-sans">

<!-- ================= NAVBAR ================= -->
<div class="bg-white/80 backdrop-blur-lg border-b border-gray-200 px-10 py-5 flex justify-between items-center shadow-sm sticky top-0 z-50">

    <h1 class="text-2xl font-bold text-gray-800 tracking-tight">
        Admin Panel
    </h1>

    <div class="flex items-center gap-6">
        <span class="text-gray-600 font-medium">
            Welcome, <span class="text-gray-900"><%= user ? user.name : "Admin" %></span>
        </span>

        <a href="/logout" 
           class="bg-red-500 hover:bg-red-600 text-white px-5 py-2 rounded-lg transition duration-200 shadow-sm">
            Logout
        </a>
    </div>
</div>

<div class="max-w-7xl mx-auto px-8 py-10">

    <!-- ================= STATS ================= -->
    <div class="grid md:grid-cols-3 gap-6 mb-10">

        <div class="bg-white p-6 rounded-2xl shadow-md">
            <p class="text-gray-500 text-sm">Total Orders</p>
            <p class="text-3xl font-bold text-gray-800 mt-2"><%= orders.length %></p>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-md">
            <p class="text-gray-500 text-sm">Total Products</p>
            <p class="text-3xl font-bold text-gray-800 mt-2"><%= products.length %></p>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-md">
            <p class="text-gray-500 text-sm">Total Revenue</p>
            <p class="text-3xl font-bold text-gray-800 mt-2">
                ₹ <%= orders.reduce((sum,o)=>sum+o.totalAmount,0) %>
            </p>
        </div>

    </div>

    <!-- ================= TAB BUTTONS ================= -->
    <div class="flex gap-4 mb-10">
        <button onclick="switchTab('orders', event)"
            class="tab-btn active-tab px-6 py-3 rounded-xl font-semibold shadow-sm transition">
            Orders
        </button>

        <button onclick="switchTab('products', event)"
            class="tab-btn px-6 py-3 rounded-xl font-semibold shadow-sm transition bg-white">
            Products
        </button>
    </div>

    <!-- ================= ORDERS SECTION ================= -->
    <div id="orders-section" class="tab-content">

        <% if (orders.length === 0) { %>
            <p class="text-gray-500">No orders available.</p>
        <% } %>

        <% orders.forEach(order => { %>
        <div class="bg-white rounded-2xl p-8 mb-8 shadow-md border border-gray-100">

            <div class="flex justify-between items-start border-b pb-5 mb-5">
                <div>
                    <h3 class="text-xl font-bold text-gray-800">
                        <%= order.user?.name || "User" %>
                    </h3>
                    <p class="text-gray-500 text-sm">
                        <%= order.user?.email || "" %>
                    </p>
                    <p class="text-xs text-gray-400 mt-2">
                        <%= new Date(order.createdAt).toLocaleString() %>
                    </p>
                </div>

                <div class="text-right">
                    <span class="px-4 py-1 rounded-full text-sm font-semibold
                        <%= order.status === 'Pending' ? 'bg-gray-200 text-gray-700' :
                            order.status === 'Preparing' ? 'bg-yellow-100 text-yellow-700' :
                            order.status === 'Delivered' ? 'bg-green-100 text-green-700' :
                            'bg-red-100 text-red-700' %>">
                        <%= order.status %>
                    </span>

                    <p class="text-2xl font-bold text-gray-900 mt-3">
                        ₹ <%= order.totalAmount %>
                    </p>
                </div>
            </div>

            <div class="space-y-3 mb-6">
                <% order.items.forEach(item => { %>
                <div class="flex justify-between bg-gray-50 p-4 rounded-xl">
                    <div>
                        <p class="font-medium text-gray-800"><%= item.name %></p>
                        <p class="text-sm text-gray-500">
                            ₹ <%= item.price %> × <%= item.quantity %>
                        </p>
                    </div>
                    <p class="font-semibold text-gray-800">
                        ₹ <%= item.price * item.quantity %>
                    </p>
                </div>
                <% }) %>
            </div>

            <div class="flex flex-wrap gap-3">
                <button onclick="updateStatus('<%= order._id %>', 'Pending')" class="status-btn bg-gray-600">Pending</button>
                <button onclick="updateStatus('<%= order._id %>', 'Preparing')" class="status-btn bg-yellow-500">Preparing</button>
                <button onclick="updateStatus('<%= order._id %>', 'Delivered')" class="status-btn bg-green-600">Delivered</button>
                <button onclick="updateStatus('<%= order._id %>', 'Cancelled')" class="status-btn bg-red-600">Cancelled</button>
            </div>

        </div>
        <% }) %>

    </div>

    <!-- ================= PRODUCTS SECTION ================= -->
    <div id="products-section" class="tab-content hidden">

        <div class="bg-white p-8 rounded-2xl shadow-md mb-10">
            <h2 class="text-xl font-bold mb-6">Add Product</h2>

            <<form action="/admin/add-product" method="POST" enctype="multipart/form-data" class="grid md:grid-cols-4 gap-4">

    <input type="text" name="name" placeholder="Product Name" required class="input-style">

    <input type="number" name="price" placeholder="Price" required class="input-style">

    <input type="text" name="category" placeholder="Category" required class="input-style">

    <!-- IMAGE UPLOAD -->
    <input type="file" name="image" accept="image/*" required class="input-style">

    <button type="submit"
        class="bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold col-span-4">
        Add Product
    </button>

</form>
        </div>

        <% products.forEach(product => { %>
        <div class="bg-white p-6 mb-5 rounded-2xl shadow flex justify-between items-center border border-gray-100">

            <div class="flex items-center gap-5">
                <img src="<%= product.image %>" class="w-20 h-20 object-cover rounded-xl">

                <div>
                    <p class="font-bold text-lg text-gray-800"><%= product.name %></p>
                    <p class="text-gray-600">₹ <%= product.price %></p>
                    <p class="text-sm text-gray-400 capitalize"><%= product.category %></p>
                </div>
            </div>

            <div class="flex items-center gap-4">

                <span class="status-badge px-4 py-1 rounded-full text-sm font-semibold
                    <%= product.isAvailable 
                        ? 'bg-green-100 text-green-700' 
                        : 'bg-red-100 text-red-700' %>">
                    <%= product.isAvailable ? "Available" : "Out of Stock" %>
                </span>

                <button 
                    onclick="toggleProduct('<%= product._id %>', this)"
                    class="px-5 py-2 rounded-xl font-semibold text-white transition
                    <%= product.isAvailable 
                        ? 'bg-green-600 hover:bg-green-700' 
                        : 'bg-gray-500 hover:bg-gray-600' %>">
                    Toggle
                </button>

            </div>

        </div>
        <% }) %>

    </div>

</div>

<style>
.active-tab { background: #111827; color: white; }
.status-btn { padding: 10px 18px; border-radius: 12px; color: white; font-size: 14px; font-weight: 600; }
.input-style { border: 1px solid #e5e7eb; padding: 12px; border-radius: 12px; outline: none; }
.input-style:focus { border-color: #2563eb; box-shadow: 0 0 0 2px rgba(37,99,235,0.2); }
</style>

<script>
function switchTab(tab, event) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
    document.getElementById(tab + '-section').classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active-tab'));
    event.target.classList.add('active-tab');
}

async function updateStatus(id, status) {
    const res = await fetch('/admin/update-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId: id, status })
    });
    if (res.ok) location.reload();
}

async function toggleProduct(id, button) {

    const res = await fetch(`/admin/toggle-product/${id}`, { method: 'POST' });
    const data = await res.json();

    if (data.success) {

        const container = button.parentElement;
        const statusSpan = container.querySelector('.status-badge');

        if (data.isAvailable) {
            statusSpan.innerText = "Available";
            statusSpan.className = "status-badge px-4 py-1 rounded-full text-sm font-semibold bg-green-100 text-green-700";
            button.className = "px-5 py-2 rounded-xl font-semibold text-white transition bg-green-600 hover:bg-green-700";
        } else {
            statusSpan.innerText = "Out of Stock";
            statusSpan.className = "status-badge px-4 py-1 rounded-full text-sm font-semibold bg-red-100 text-red-700";
            button.className = "px-5 py-2 rounded-xl font-semibold text-white transition bg-gray-500 hover:bg-gray-600";
        }

    } else {
        alert("Error updating product");
    }
}
</script>

</body>
</html>