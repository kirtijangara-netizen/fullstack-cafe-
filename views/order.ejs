<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Orders | Gourmet Hub</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50 pb-12">

<%- include("partials/navbar", { user: user }) %>

<div class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-8">
        <h2 class="text-3xl font-extrabold text-gray-900">Welcome, <%= user.name %> 👋</h2>
        <p class="text-gray-500">Manage your current cart and view your order history.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-emerald-100 overflow-hidden mb-10">
        <div class="bg-emerald-50 px-6 py-4 border-b border-emerald-100 flex items-center gap-2">
            <i class="fa fa-shopping-basket text-emerald-600"></i>
            <h3 class="font-bold text-emerald-800 uppercase tracking-wider text-sm">Active Cart Items</h3>
        </div>
        <div class="p-6">
            <div id="cartItems" class="space-y-3 mb-6 text-gray-700">
                </div>
            
            <div class="flex flex-col md:flex-row justify-between items-center pt-4 border-t border-gray-100 gap-4">
                <div class="text-2xl font-bold text-gray-900">
                    Total: <span class="text-emerald-600">₹<span id="totalAmount">0</span></span>
                </div>
                <button onclick="placeOrder()" class="w-full md:w-auto bg-emerald-600 hover:bg-emerald-700 text-white px-8 py-3 rounded-xl font-bold transition-all shadow-lg shadow-emerald-200 flex items-center justify-center gap-2">
                    <i class="fa fa-check-circle"></i> Place Order Now
                </button>
            </div>
        </div>
    </div>

    <hr class="border-gray-200 mb-10">

    <h2 class="text-2xl font-bold text-gray-800 mb-6 flex items-center gap-2">
        <i class="fa fa-history text-blue-500"></i> Your Previous Orders
    </h2>

    <% if (orders.length === 0) { %>
        <div class="text-center py-12 bg-white rounded-2xl border border-dashed border-gray-300">
            <i class="fa fa-receipt text-4xl text-gray-300 mb-3"></i>
            <p class="text-gray-500">No previous orders found.</p>
        </div>
    <% } %>

    <div class="space-y-6">
        <% orders.forEach(order => { %>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                <div class="p-6">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-4 gap-4">
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase">Order ID</p>
                            <p class="font-mono text-sm text-gray-600">#<%= order._id %></p>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="px-4 py-1 rounded-full text-xs font-black uppercase 
                                <%= order.status === 'Pending' ? 'bg-amber-100 text-amber-700' : 
                                   order.status === 'Preparing' ? 'bg-blue-100 text-blue-700' : 
                                   'bg-emerald-100 text-emerald-700' %>">
                                <%= order.status === 'Pending' ? '🟡' : order.status === 'Preparing' ? '🔵' : '🟢' %> <%= order.status %>
                            </span>
                            <p class="text-xl font-black text-gray-900">₹<%= order.totalAmount %></p>
                        </div>
                    </div>

                    <div class="bg-gray-50 rounded-xl p-4 mb-4">
                        <p class="text-xs font-bold text-gray-400 uppercase mb-2">Items</p>
                        <ul class="space-y-1">
                            <% order.items.forEach(item => { %>
                                <li class="text-sm text-gray-700 flex justify-between">
                                    <span><%= item.name %> <span class="text-gray-400">x<%= item.quantity %></span></span>
                                    <span class="font-medium text-gray-500">₹<%= item.price * item.quantity %></span>
                                </li>
                            <% }) %>
                        </ul>
                    </div>

                    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                        <p class="text-sm text-gray-500">
                            <i class="fa fa-clock mr-1"></i> Pickup: <span class="font-semibold text-gray-700"><%= order.pickupTime %></span>
                        </p>
                        
                        <button onclick='handleReorder(<%- JSON.stringify(order.items) %>)' 
                                class="w-full md:w-auto bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white px-6 py-2 rounded-lg font-bold transition-all border border-blue-100 flex items-center justify-center gap-2">
                            <i class="fa fa-redo text-sm"></i> Reorder Items
                        </button>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include("partials/footer") %>

<script>
document.addEventListener("DOMContentLoaded", () => {
    renderActiveCart();
});

function renderActiveCart() {
    const cart = JSON.parse(localStorage.getItem("cart")) || [];
    const cartContainer = document.getElementById("cartItems");
    const totalEl = document.getElementById("totalAmount");

    let total = 0;
    cartContainer.innerHTML = "";

    if (cart.length === 0) {
        cartContainer.innerHTML = `
            <div class="text-center py-4">
                <p class="text-gray-400 italic">Your cart is currently empty.</p>
                <a href="/products" class="text-emerald-600 font-bold text-sm underline hover:text-emerald-700">Browse Menu</a>
            </div>`;
    } else {
        cart.forEach(item => {
            const div = document.createElement("div");
            div.className = "flex justify-between items-center py-2 border-b border-gray-50 last:border-0";
            div.innerHTML = `
                <span class="font-medium">${item.name} <span class="text-gray-400 text-sm ml-2">x${item.quantity}</span></span>
                <span class="font-bold text-gray-900">₹${item.price * item.quantity}</span>
            `;
            cartContainer.appendChild(div);
            total += item.price * item.quantity;
        });
    }
    totalEl.innerText = total;
}

function handleReorder(items) {
    if(confirm("Add these items to your cart and proceed to checkout?")) {
        const cartData = items.map(item => ({
            productId: item.productId,
            name: item.name,
            price: item.price,
            quantity: item.quantity,
            stock: 999 
        }));

        localStorage.setItem("cart", JSON.stringify(cartData));
        window.location.href = "/cart"; 
    }
}

async function placeOrder() {
    const cart = JSON.parse(localStorage.getItem("cart")) || [];
    if (cart.length === 0) {
        alert("Your cart is empty!");
        return;
    }

    const pickupTime = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

    try {
        const res = await fetch("/order", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ items: cart, pickupTime })
        });

        const data = await res.json();

        if (data.success) {
            localStorage.removeItem("cart");
            window.location.href = "/order";
        } else {
            alert(data.message);
        }
    } catch (err) {
        alert("Failed to connect to server.");
    }
}
</script>
</body>
</html>