<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gourmet Hub | Products</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .product-card:hover img { transform: scale(1.05); }
        .active-filter { background-color: #2563eb !important; color: white !important; }
    </style>
</head>
<body class="pb-12">

    <%- include("partials/navbar",{user:user}) %>

    <div class="bg-white border-b px-6 py-10 mb-8">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">Our Menu</h1>
                <p class="text-gray-500 mt-2 text-lg">Delicious food delivered straight to your door.</p>
            </div>

            <form method="GET" action="/products" class="relative w-full md:w-96">
                <input type="hidden" name="category" value="<%= selectedCategory %>">
                <input type="text" name="search" placeholder="Search for delicacies..." 
                    value="<%= search || '' %>"
                    class="w-full pl-12 pr-4 py-3 rounded-full border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none shadow-sm transition-all">
                <i class="fa fa-search absolute left-5 top-4 text-gray-400"></i>
                <button type="submit" class="absolute right-2 top-2 bg-blue-600 text-white px-5 py-1.5 rounded-full text-sm font-semibold hover:bg-blue-700 transition">Go</button>
            </form>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6">
        
        <div class="flex flex-wrap gap-3 mb-10">
            <% ['all', 'fast food', 'desserts', 'drinks'].forEach(cat => { %>
                <a href="/products?category=<%= cat %>&search=<%= search || '' %>" 
                    class="px-6 py-2 rounded-full border border-gray-200 bg-white text-gray-700 font-medium hover:bg-gray-50 transition-all capitalize shadow-sm <%= selectedCategory === cat ? 'active-filter' : '' %>">
                    <%= cat %>
                </a>
            <% }) %>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <% if(products && products.length > 0){ %>
                <% products.forEach(product => { %>
                    <div class="product-card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
                        <div class="relative overflow-hidden aspect-square cursor-pointer" 
                             onclick="showProductPopup('<%= product._id %>','<%= product.name %>','<%= product.image %>', '<%= product.price %>', `<%= product.description %>`, <%= product.stock %>)">
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover transition-transform duration-500">
                            
                            <div class="absolute top-3 right-3 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-sm font-bold text-gray-800 shadow-sm">
                                ₹<%= product.price %>
                            </div>

                            <div class="absolute top-3 left-3">
                                <% if (product.stock > 0) { %>
                                    <span class="bg-emerald-500 text-white text-[10px] font-black px-2 py-1 rounded-lg uppercase shadow-lg">In Stock</span>
                                <% } else { %>
                                    <span class="bg-red-500 text-white text-[10px] font-black px-2 py-1 rounded-lg uppercase shadow-lg">Sold Out</span>
                                <% } %>
                            </div>
                        </div>

                        <div class="p-5 flex flex-col flex-grow text-center">
                            <h3 class="text-lg font-bold text-gray-800 mb-1"><%= product.name %></h3>
                            <p class="text-gray-500 text-xs mb-4 uppercase tracking-wider font-semibold"><%= product.category %></p>
                            
                            <% if (product.stock > 0) { %>
                                <button class="w-full bg-gray-900 text-white py-3 rounded-xl font-bold hover:bg-blue-600 transform active:scale-95 transition-all mt-auto"
                                        onclick="addToCart('<%= product._id %>','<%= product.name %>', <%= product.price %>, <%= product.stock %>)">
                                    Add to Cart
                                </button>
                            <% } else { %>
                                <button disabled class="w-full bg-gray-200 text-gray-400 py-3 rounded-xl font-bold cursor-not-allowed mt-auto">
                                    Out of Stock
                                </button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center">
                    <i class="fa fa-utensils text-5xl text-gray-200 mb-4"></i>
                    <p class="text-xl text-gray-500 font-medium">No delicacies found in this category.</p>
                </div>
            <% } %>
        </div>

        <% if(totalPages > 1){ %>
            <div class="flex justify-center items-center gap-2 mt-16">
                <% for(let i=1; i<=totalPages; i++){ %>
                    <a href="/products?page=<%= i %>&category=<%= selectedCategory %>&search=<%= search || '' %>" 
                       class="w-10 h-10 flex items-center justify-center rounded-lg font-bold transition-all border <%= i === currentPage ? 'bg-blue-600 text-white border-blue-600 shadow-lg shadow-blue-200' : 'bg-white text-gray-600 hover:border-blue-500' %>">
                       <%= i %>
                    </a>
                <% } %>
            </div>
        <% } %>
    </div>

    <div id="productPopup" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-[2000] items-center justify-center p-4">
        <div class="bg-white rounded-3xl overflow-hidden shadow-2xl max-w-lg w-full relative animate-in fade-in zoom-in duration-300">
            <button onclick="closePopup()" class="absolute top-4 right-4 bg-white/80 hover:bg-red-500 hover:text-white w-10 h-10 rounded-full flex items-center justify-center transition-all z-10">
                <i class="fa fa-times"></i>
            </button>
            <img id="popupImage" class="w-full h-64 object-cover">
            <div class="p-8">
                <div class="flex justify-between items-start mb-2">
                    <h2 id="popupName" class="text-3xl font-extrabold text-gray-900 leading-tight"></h2>
                    <span id="popupPrice" class="text-2xl font-bold text-blue-600"></span>
                </div>
                <p id="popupStock" class="text-xs font-black uppercase mb-4"></p>

                <p id="popupDescription" class="text-gray-600 leading-relaxed mb-8 text-lg"></p>
                
                <button id="popupCartBtn" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold text-lg hover:bg-blue-700 shadow-lg transition-all flex items-center justify-center gap-2">
                    <i class="fa fa-shopping-basket"></i> Add to Cart
                </button>
            </div>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script>
        const cartCountEl = document.getElementById("cartCount");

        // Helper to check what's actually left
        function getRemainingStock(productId, databaseStock) {
            const cart = JSON.parse(localStorage.getItem("cart")) || [];
            const itemInCart = cart.find(item => item.productId === productId);
            const quantityInCart = itemInCart ? itemInCart.quantity : 0;
            return databaseStock - quantityInCart;
        }

        function updateCartCount() {
            const cart = JSON.parse(localStorage.getItem("cart")) || [];
            const total = cart.reduce((sum, item) => sum + item.quantity, 0);
            if (cartCountEl) cartCountEl.innerText = total;
        }

        function addToCart(productId, name, price, databaseStock) {
            let cart = JSON.parse(localStorage.getItem("cart")) || [];
            const existing = cart.find(item => item.productId === productId);
            
            const currentQtyInCart = existing ? existing.quantity : 0;
            
            // 🔥 BLOCK ADDITION IF OUT OF STOCK
            if (currentQtyInCart >= databaseStock) {
                alert(`Sorry! This product is currently out of stock.`);
                return;
            }

            if (existing) {
                existing.quantity++;
            } else {
                // ✅ We save 'stock' into the object so the Cart page can use it too
                cart.push({ 
                    productId, 
                    name, 
                    price: parseFloat(price), 
                    quantity: 1, 
                    stock: databaseStock 
                });
            }

            localStorage.setItem("cart", JSON.stringify(cart));
            updateCartCount();
            
            // Notification
            const notify = document.createElement("div");
            notify.className = "fixed bottom-5 right-5 bg-gray-900 text-white px-6 py-3 rounded-xl shadow-2xl z-[5000] animate-bounce";
            notify.innerText = "Added to your basket! 🍔";
            document.body.appendChild(notify);
            
            setTimeout(() => {
                notify.remove();
                // If popup is open, update UI immediately
                if(document.getElementById("productPopup").style.display === "flex") {
                    const currentDesc = document.getElementById("popupDescription").innerText;
                    const currentImg = document.getElementById("popupImage").src;
                    showProductPopup(productId, name, currentImg, price, currentDesc, databaseStock);
                }
            }, 800);
        }

        function showProductPopup(id, name, image, price, description, databaseStock) {
            const remaining = getRemainingStock(id, databaseStock);
            
            document.getElementById("productPopup").style.display = "flex";
            document.getElementById("popupImage").src = image;
            document.getElementById("popupName").innerText = name;
            document.getElementById("popupPrice").innerText = "₹" + price;
            document.getElementById("popupDescription").innerText = description || "No description available.";
            
            const stockEl = document.getElementById("popupStock");
            const cartBtn = document.getElementById("popupCartBtn");

            if (remaining > 0) {
                stockEl.innerText = `Only ${remaining} items left in stock!`;
                stockEl.className = "text-emerald-600 text-xs font-black uppercase mb-4";
                cartBtn.disabled = false;
                cartBtn.innerText = "Add to Cart";
                cartBtn.className = "w-full bg-blue-600 text-white py-4 rounded-2xl font-bold text-lg hover:bg-blue-700 shadow-lg transition-all flex items-center justify-center gap-2";
                
                cartBtn.onclick = function() {
                    addToCart(id, name, price, databaseStock);
                }
            } else {
                stockEl.innerText = "Out of Stock / Max quantity in cart";
                stockEl.className = "text-red-500 text-xs font-black uppercase mb-4";
                cartBtn.disabled = true;
                cartBtn.innerText = "Out of Stock";
                cartBtn.className = "w-full bg-gray-200 text-gray-400 py-4 rounded-2xl font-bold text-lg cursor-not-allowed flex items-center justify-center gap-2";
            }
        }

        function closePopup() {
            document.getElementById("productPopup").style.display = "none";
        }

        updateCartCount();
    </script>
</body>
</html>