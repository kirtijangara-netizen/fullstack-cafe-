
<!DOCTYPE html>
<html>
<head>
<title>Food Products</title>

<style>
body{
font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
background:#fafafa;
margin:0;
padding:25px;
color:#333;
}

h1{
font-size:32px;
margin-bottom:20px;
color:#222;
}

/* SEARCH BAR */

.search-bar{
margin-bottom:25px;
display:flex;
gap:10px;
}

.search-bar input{
padding:12px;
width:280px;
border-radius:8px;
border:1px solid #ddd;
font-size:14px;
outline:none;
transition:0.3s;
}

.search-bar input:focus{
border-color:#007bff;
box-shadow:0 0 5px rgba(0,123,255,0.4);
}

.search-bar button{
padding:12px 18px;
border:none;
background:#007bff;
color:white;
border-radius:8px;
cursor:pointer;
font-weight:600;
transition:0.3s;
}

.search-bar button:hover{
background:#0056b3;
}

/* FILTER BUTTONS */

.filter-section{
margin-bottom:30px;
}

.filter-btn{
padding:8px 16px;
margin-right:10px;
border-radius:25px;
background:#e0e0e0;
color:#333;
text-decoration:none;
font-size:14px;
font-weight:500;
transition:0.3s;
}

.filter-btn:hover{
background:#007bff;
color:white;
}

.active-filter{
background:#007bff;
color:white;
}

/* PRODUCT GRID */

.container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
gap:25px;
}

/* PRODUCT CARD */

.card{
background:white;
padding:15px;
border-radius:12px;
text-align:center;
box-shadow:0 5px 15px rgba(0,0,0,0.08);
transition:0.3s;
position:relative;
overflow:hidden;
}

.card:hover{
transform:translateY(-8px);
box-shadow:0 10px 25px rgba(0,0,0,0.15);
}

.card img{
width:100%;
height:170px;
object-fit:cover;
border-radius:10px;
cursor:pointer;
transition:0.3s;
}

.card img:hover{
transform:scale(1.05);
}

.card h3{
margin:12px 0 5px;
font-size:18px;
font-weight:600;
}

.card p{
font-size:16px;
color:black;
font-weight:600;
}

/* ADD TO CART BUTTON */

.add-cart-btn{
margin-top:10px;
padding:10px 16px;
background:linear-gradient(black);
color:white;
border:none;
border-radius:6px;
cursor:pointer;
font-size:14px;
font-weight:600;
transition:0.3s;
}

.add-cart-btn:hover{
background:linear-gradient(black);
transform:scale(1.05);
}

/* PAGINATION */

.pagination{
margin-top:35px;
text-align:center;
}

.page-btn{
padding:10px 14px;
margin:5px;
border-radius:6px;
background:#e0e0e0;
text-decoration:none;
color:#333;
font-weight:500;
transition:0.3s;
}

.page-btn:hover{
background:brown;
color:white;
}

.active-page{
background:brown;
color:white;
}

/* POPUP */

.popup{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.6);
justify-content:center;
align-items:center;
z-index:1000;
backdrop-filter:blur(3px);
}

.popup-content{
background:white;
padding:25px;
border-radius:12px;
text-align:center;
width:340px;
position:relative;
animation:popupAnim 0.3s ease;
box-shadow:0 10px 30px rgba(0,0,0,0.25);
}

@keyframes popupAnim{
from{
transform:scale(0.8);
opacity:0;
}
to{
transform:scale(1);
opacity:1;
}
}

.popup-content img{
width:100%;
height:200px;
object-fit:cover;
border-radius:10px;
margin-bottom:10px;
}

.close{
position:absolute;
right:15px;
top:12px;
font-size:22px;
cursor:pointer;
color:#555;
}

.close:hover{
color:red;
}

.no-products{
font-size:18px;
color:red;
margin-top:20px;
}

@media(max-width:900px){
.container{
grid-template-columns:repeat(2,1fr);
}
}

@media(max-width:500px){
.container{
grid-template-columns:1fr;
}
}

</style>
</head>

<body>

<%- include("partials/navbar",{user:user}) %>

<h1>Food Products</h1>

<form method="GET" action="/products" class="search-bar">

<input type="hidden" name="category" value="<%= selectedCategory %>">

<input
type="text"
name="search"
placeholder="Search product..."
value="<%= search || '' %>"
>

<button type="submit">Search</button>

</form>

<div class="filter-section">

<a href="/products?category=all&search=<%= search || '' %>"
class="filter-btn <%= selectedCategory==='all' ? 'active-filter':'' %>">All</a>

<a href="/products?category=fast food&search=<%= search || '' %>"
class="filter-btn <%= selectedCategory==='fast food' ? 'active-filter':'' %>">Fast Food</a>

<a href="/products?category=desserts&search=<%= search || '' %>"
class="filter-btn <%= selectedCategory==='desserts' ? 'active-filter':'' %>">Desserts</a>

<a href="/products?category=drinks&search=<%= search || '' %>"
class="filter-btn <%= selectedCategory==='drinks' ? 'active-filter':'' %>">Drinks</a>

</div>

<div class="container">

<% if(products && products.length>0){ %>

<% products.forEach(product=>{ %>

<div class="card">

<img
src="<%= product.image %>"
alt="<%= product.name %>"
onclick="showProductPopup('<%= product._id %>','<%= product.name %>','<%= product.image %>',<%= product.price %>)"
>

<h3><%= product.name %></h3>

<p>₹<%= product.price %></p>

<button class="add-cart-btn"
onclick="addToCart('<%= product._id %>','<%= product.name %>',<%= product.price %>)">
Add To Cart
</button>

</div>

<% }) %>

<% } else { %>

<p class="no-products">No products found</p>

<% } %>

</div>

<div class="pagination">

<% if(totalPages>1){ %>

<% for(let i=1;i<=totalPages;i++){ %>

<a
href="/products?page=<%= i %>&category=<%= selectedCategory %>&search=<%= search || '' %>"
class="page-btn <%= i===currentPage ? 'active-page':'' %>">
<%= i %>
</a>

<% } %>

<% } %>

</div>

<div id="productPopup" class="popup">

<div class="popup-content">

<span class="close" onclick="closePopup()">×</span>

<img id="popupImage">

<h2 id="popupName"></h2>

<p id="popupPrice"></p>

<button id="popupCartBtn" class="add-cart-btn">Add To Cart</button>

</div>

</div>

<%- include("partials/footer") %>

<script>

const cartCountEl=document.getElementById("cartCount")

function updateCartCount(){

const cart=JSON.parse(localStorage.getItem("cart"))||[]

const total=cart.reduce((sum,item)=>sum+item.quantity,0)

if(cartCountEl) cartCountEl.innerText=total

}

function addToCart(productId,name,price){

let cart=JSON.parse(localStorage.getItem("cart"))||[]

const existing=cart.find(item=>item.productId===productId)

if(existing){

existing.quantity++

}else{

cart.push({
productId:productId,
name:name,
price:parseFloat(price),
quantity:1
})

}

localStorage.setItem("cart",JSON.stringify(cart))

updateCartCount()

alert("Item added to cart")

}

function showProductPopup(id,name,image,price){

document.getElementById("productPopup").style.display="flex"

document.getElementById("popupImage").src=image
document.getElementById("popupName").innerText=name
document.getElementById("popupPrice").innerText="₹"+price

document.getElementById("popupCartBtn").onclick=function(){
addToCart(id,name,price)
}

}

function closePopup(){
document.getElementById("productPopup").style.display="none"
}

updateCartCount()

</script>

</body>
</html>
